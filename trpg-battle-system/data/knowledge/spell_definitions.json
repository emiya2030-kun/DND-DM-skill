    "counterspell": {
      "id": "counterspell",
      "name": "Counterspell",
      "level": 3,
      "save_ability": "con",
      "requires_attack_roll": false,
      "localization": {
        "name_zh": "法术反制",
        "name_en": "Counterspell",
        "rules_text_zh": "你试图打断一名正在施法的生物。该生物进行一次体质豁免。豁免失败则法术消散且毫无效果，并且用于施展法术的动作、附赠动作或反应随之浪费。如果那道法术是使用法术位施展的，则法术位并不会被消耗。",
        "rules_text_en": "You try to interrupt a creature in the process of casting a spell. The creature makes a Constitution saving throw. On a failed save, the spell fizzles with no effect, and the action, Bonus Action, or Reaction used to cast it is wasted. If the interrupted spell used a spell slot, that slot is not expended."
      },
      "usage_contexts": ["combat"],
      "runtime_support": {
        "in_encounter": "implemented",
        "out_of_encounter": "template_only"
      },
      "source": {
