    "hunters_mark": {
      "id": "hunters_mark",
      "name": "Hunter's Mark",
      "level": 1,
      "save_ability": null,
      "requires_attack_roll": false,
      "localization": {
        "name_zh": "猎人印记",
        "name_en": "Hunter's Mark",
        "rules_text_zh": "你神秘地标记一个施法距离内你能看见的生物作为你的猎物。直到法术终止前，你每回合第一次以武器攻击命中被标记目标时，目标将额外受到1d6点力场伤害。如果目标在法术终止前HP降至0，则你可以在后续某一回合中使用一个附赠动作将印记转移到你能看见的另一个生物身上。",
        "rules_text_en": "You mystically mark one creature you can see within range as your quarry. Until the spell ends, the first time each turn you hit the marked target with a weapon attack, it takes an extra 1d6 Force damage. If the target drops to 0 hit points before this spell ends, you can take a bonus action on a later turn to mark a new creature you can see."
      },
      "usage_contexts": ["combat", "exploration"],
      "runtime_support": {
